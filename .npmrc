# Required for the Sanity 5.x toolchain on a React 18 host project.
#
# `sanity`, `@sanity/vision`, and several `@portabletext/plugin-*` packages
# declare `react@^19.2` as a peer. Glatko is on React 18; the Studio CLI
# (`npm run studio:dev`) runs as a separate process so this peer mismatch
# is harmless at runtime, but plain `npm install` would still fail at
# resolution time and block CI / Vercel builds. `legacy-peer-deps` tells
# npm to install regardless and let the tools sort it out.
#
# When Glatko upgrades to React 19, this file can be deleted.
legacy-peer-deps=true
