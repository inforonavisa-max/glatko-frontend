# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Upstash Redis
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Mapbox
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=

# OpenAI
OPENAI_API_KEY=

# Email (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@glatko.app
# Notification emails (new bid/quote/message/status/etc.): OFF unless "true".
# Auth (email-hook) + transactional (request/pro/founding/profile) emails are
# unaffected. Faz 2 keeps this off permanently (WhatsApp/Viber replace it).
NOTIFICATION_EMAILS_ENABLED=

# Cron
CRON_SECRET=

# App
NEXT_PUBLIC_APP_URL=

# Admin (comma-separated). If unset, see default list in lib/admin.ts
ADMIN_EMAILS=

# Support (optional)
NEXT_PUBLIC_WHATSAPP_SUPPORT=
NEXT_PUBLIC_VIBER_SUPPORT=

# Rate limiting
RATE_LIMIT_SALT=

# ========================================
# Infobip SMS (Sprint A — phone verification)
# ========================================
# App key with the sms:message:send scope — Portal > Developer Tools > API Keys.
# SECRET — server-side only, never NEXT_PUBLIC_
INFOBIP_API_KEY=
# Personalized base host from the Infobip portal homepage, e.g. z445v6.api.infobip.com
INFOBIP_BASE_URL=
# Approved alphanumeric sender ID (Montenegro-registered), e.g. Glatko
INFOBIP_SMS_SENDER=

# ========================================
# Supabase Send SMS Hook (Sprint A)
# ========================================
# Secret from Supabase Dashboard > Authentication > Hooks > Send SMS hook.
# Mirrors SUPABASE_AUTH_HOOK_SECRET (Send Email hook). Format: v1,whsec_...
# SECRET — server-side only
SEND_SMS_HOOK_SECRET=

# ========================================
# Google Tag Manager (G-ADS-2)
# ========================================
# Container ID (e.g. GTM-XXXXXXX) — see docs/ads-credentials.md
# Public env var: GTM container ID secret değil, client-side OK
NEXT_PUBLIC_GTM_ID=

# ========================================
# Meta Pixel + Conversions API (G-ADS-4)
# ========================================
# Pixel ID — DOO sonrası Meta Business Manager > Pixel > ID
# Public env: client-side Pixel script bu ID ile yüklenecek
NEXT_PUBLIC_META_PIXEL_ID=

# Conversions API Access Token — Meta Business Manager > Events Manager > Settings > Generate token
# SECRET — server-side only, never NEXT_PUBLIC_
META_CAPI_ACCESS_TOKEN=

# Test event code (optional) — Events Manager > Test Events > Test event code
# Production'da boş bırak, test sırasında doldur
META_CAPI_TEST_EVENT_CODE=

# ========================================
# Meta Domain Verification (G-ADS-7a-domain)
# ========================================
# facebook-domain-verification meta tag content — Meta Business > Brand Safety > Domains
# Public token (HTML'de görünür), env-gated; Vercel Sensitive OFF
FACEBOOK_DOMAIN_VERIFICATION=
