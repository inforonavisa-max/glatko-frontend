# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Upstash Redis
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Mapbox
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=

# OpenAI
OPENAI_API_KEY=

# Email (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@glatko.app

# Cron
CRON_SECRET=

# App
NEXT_PUBLIC_APP_URL=

# Admin (comma-separated). If unset, see default list in lib/admin.ts
ADMIN_EMAILS=

# Support (optional)
NEXT_PUBLIC_WHATSAPP_SUPPORT=
NEXT_PUBLIC_VIBER_SUPPORT=

# Rate limiting
RATE_LIMIT_SALT=

# ========================================
# Google Tag Manager (G-ADS-2)
# ========================================
# Container ID (e.g. GTM-XXXXXXX) — see docs/ads-credentials.md
# Public env var: GTM container ID secret değil, client-side OK
NEXT_PUBLIC_GTM_ID=
