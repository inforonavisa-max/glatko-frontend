{
  "framework": "nextjs",
  "ignoreCommand": "git diff --quiet HEAD^ HEAD -- ':!**/*.md' ':!docs/**' ':!.github/**' ':!supabase/migrations/**'",
  "crons": [
    {
      "path": "/api/cron/expire-requests",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/activate-waitlists",
      "schedule": "*/5 * * * *"
    }
  ]
}
