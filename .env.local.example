# Glatko frontend env vars — local development sample.
# Copy to .env.local and fill the secret values from the relevant dashboards.
# Never commit .env.local. Vercel mirrors these in Project Settings → Environment Variables.

# ─── Supabase (existing) ─────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Sanity CMS (G-CMS-1) ────────────────────────────────────────────────────
# Public — embedded in client bundle, safe to expose
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2025-02-19

# Server-only — never prefix with NEXT_PUBLIC_
SANITY_API_READ_TOKEN=
SANITY_API_WRITE_TOKEN=
